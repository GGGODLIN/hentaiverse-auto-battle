{
  "manifest_version": 3,
  "name": "HV Auto Arena",
  "version": "4.1",
  "description": "Auto battle, arena sweep, and encounter farming for HentaiVerse",
  "permissions": ["storage", "alarms", "tabs", "notifications", "scripting"],
  "host_permissions": [
    "*://hentaiverse.org/*",
    "*://www.hentaiverse.org/*",
    "*://e-hentai.org/*",
    "*://www.e-hentai.org/*",
    "*://rdma.ooguy.com/*",
    "*://forums.e-hentai.org/*",
    "*://hvmarket.xyz/*",
    "*://reasoningtheory.net/*",
    "*://update.sleazyfork.org/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://hentaiverse.org/*", "*://www.hentaiverse.org/*"],
      "js": ["content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://hentaiverse.org/*", "*://www.hentaiverse.org/*"],
      "js": ["content/battle.js", "content/arena.js", "content/ring-of-blood.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://e-hentai.org/news.php*", "*://www.e-hentai.org/news.php*"],
      "js": ["content/encounter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://hentaiverse.org/*", "*://www.hentaiverse.org/*"],
      "js": ["shared/translation-constants.js", "content/translations/loader.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://forums.e-hentai.org/*showtopic=*", "*://hvmarket.xyz/*", "*://reasoningtheory.net/*"],
      "js": ["shared/translation-constants.js", "content/translations/loader.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "HV Auto Arena"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/translations/gm-polyfill.js"],
      "matches": [
        "*://hentaiverse.org/*",
        "*://www.hentaiverse.org/*",
        "*://forums.e-hentai.org/*",
        "*://hvmarket.xyz/*",
        "*://reasoningtheory.net/*"
      ]
    }
  ]
}
